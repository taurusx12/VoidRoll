generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
  DIVINE
  SECRET
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

enum AuctionStatus {
  ACTIVE
  ENDED
  CANCELLED
}

enum EquipmentSlot {
  WEAPON
  ARMOR
  RING
  ARTIFACT
}

model User {
  id String @id
  username String?
  gold BigInt @default(1000)
  gems Int @default(0)
  xp Int @default(0)
  level Int @default(1)
  dailyStreak Int @default(0)
  lastDailyAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cards UserCard[]
  equipment UserEquipment[]
  listings MarketListing[]
  deployments Deployment[]
}

model Character {
  id String @id
  name String
  anime String
  rarity Rarity
  element String @default("Neutral")
  imageUrl String?
  auraName String?
  auraColor String?
  auraSecondary String?
  auraIntensity Float @default(1.0)
  basePower Int
  baseFarm Int
  baseLuck Int
  globalPrint Int @default(0)
  limited Boolean @default(false)
  banner String?
  active Boolean @default(true)
  createdAt DateTime @default(now())
  cards UserCard[]
}

model UserCard {
  id String @id
  userId String
  characterId String
  serial Int
  level Int @default(1)
  xp Int @default(0)
  power Int
  locked Boolean @default(false)
  shiny Boolean @default(false)
  trait String?
  obtainedAt DateTime @default(now())
  user User @relation(fields:[userId], references:[id])
  character Character @relation(fields:[characterId], references:[id])
  listings MarketListing[]
  deployments Deployment[]
  @@index([userId])
  @@index([characterId, serial])
}

model EquipmentTemplate {
  id String @id
  name String
  slot EquipmentSlot
  rarity Rarity
  basePower Int
  imageUrl String?
  active Boolean @default(true)

userEquipments UserEquipment[]
}

model UserEquipment {
  id String @id
  userId String
  templateId String
  level Int @default(1)
  power Int
  locked Boolean @default(false)
  createdAt DateTime @default(now())
  user User @relation(fields:[userId], references:[id])
  template EquipmentTemplate @relation(fields:[templateId], references:[id])
}

model MarketListing {
  id String @id
  sellerId String
  cardId String
  price BigInt
  status ListingStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  soldAt DateTime?
  seller User @relation(fields:[sellerId], references:[id])
  card UserCard @relation(fields:[cardId], references:[id])
  @@index([status, createdAt])
}

model Auction {
  id String @id
  cardId String
  sellerId String
  currentBid BigInt @default(0)
  currentBidderId String?
  endsAt DateTime
  status AuctionStatus @default(ACTIVE)
  createdAt DateTime @default(now())
}

model Deployment {
  id String @id
  userId String
  cardId String
  zone String
  startedAt DateTime @default(now())
  endsAt DateTime
  claimed Boolean @default(false)
  user User @relation(fields:[userId], references:[id])
  card UserCard @relation(fields:[cardId], references:[id])
}

model EconomyLog {
  id String @id
  userId String
  type String
  amount BigInt
  metadata Json?
  createdAt DateTime @default(now())
  @@index([userId, createdAt])
}

model Cooldown {
  userId String
  key String
  expiresAt DateTime
  @@id([userId, key])
}
