{
  "projectName": "VoidRoll Reborn",
  "phase": "Phase 11 - Secret / Voidborn Card Reveal",
  "rules": {
    "secretReveal": true,
    "voidbornReveal": true,
    "bottomUpReveal": true,
    "quoteBeforeImage": true,
    "audioDisabled": true,
    "noItemRolls": true,
    "noFusion": true,
    "noStars": true
  },
  "rarityRevealTypes": {
    "COMMON": "NORMAL",
    "RARE": "NORMAL",
    "EPIC": "NORMAL",
    "LEGENDARY": "RARE_FLASH",
    "MYTHIC": "MYTHIC_FLASH",
    "DIVINE": "DIVINE_REVEAL",
    "VOIDBORN": "VOIDBORN_BOTTOM_UP",
    "SECRET": "SECRET_BOTTOM_UP"
  },
  "revealSteps": {
    "SECRET_BOTTOM_UP": [
      {
        "step": 1,
        "key": "VOID_SPARK",
        "title": "Void Spark",
        "description": "A void sigil glows at the bottom of the card."
      },
      {
        "step": 2,
        "key": "BOTTOM_DISTORTION",
        "title": "Bottom Distortion",
        "description": "Void energy rises from the bottom upward."
      },
      {
        "step": 3,
        "key": "QUOTE_ASCENDS",
        "title": "Quote Ascends",
        "description": "The character quote appears before the image."
      },
      {
        "step": 4,
        "key": "SECRET_FLASH",
        "title": "Secret Flash",
        "description": "A cinematic SECRET flash covers the card."
      },
      {
        "step": 5,
        "key": "CHARACTER_REVEAL",
        "title": "Character Reveal",
        "description": "The full Secret card appears."
      }
    ],
    "VOIDBORN_BOTTOM_UP": [
      {
        "step": 1,
        "key": "VOID_PULSE",
        "title": "Void Pulse",
        "description": "Voidborn aura pulses at the bottom."
      },
      {
        "step": 2,
        "key": "RISING_AURA",
        "title": "Rising Aura",
        "description": "Aura rises from bottom to top."
      },
      {
        "step": 3,
        "key": "VOIDBORN_FLASH",
        "title": "Voidborn Flash",
        "description": "VOIDBORN rarity appears."
      },
      {
        "step": 4,
        "key": "CHARACTER_REVEAL",
        "title": "Character Reveal",
        "description": "The full Voidborn card appears."
      }
    ],
    "DIVINE_REVEAL": [
      {
        "step": 1,
        "key": "DIVINE_GLOW",
        "title": "Divine Glow",
        "description": "Divine light reveals the card."
      },
      {
        "step": 2,
        "key": "CHARACTER_REVEAL",
        "title": "Character Reveal",
        "description": "The full Divine card appears."
      }
    ]
  },
