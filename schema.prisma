generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
  DIVINE
  VOIDBORN
  SECRET
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

enum AuctionStatus {
  ACTIVE
  ENDED
  CANCELLED
}

enum EquipmentSlot {
  WEAPON
  ARMOR
  RING
  ARTIFACT
}

model User {
  id                 String            @id
  username           String?
  gold               BigInt            @default(1000)
  gems               Int               @default(0)
  tokens             Int               @default(0)
  essence            Int               @default(0)
  voidCrystals       Int               @default(0)
  soulFragments      Int               @default(0)
  pvpRating          Int               @default(1000)
  pvpWins            Int               @default(0)
  pvpLosses          Int               @default(0)
  pvpWinStreak       Int               @default(0)
  chapter            Int               @default(1)
  stage              Int               @default(1)
  rolls              Int               @default(15)
  lastRollRefillAt   DateTime          @default(now())
  lastPassiveClaimAt DateTime?
  xp                 Int               @default(0)
  level              Int               @default(1)
  dailyStreak        Int               @default(0)
  lastDailyAt         DateTime?
  meta               Json?             @default("{}")

  // Compatibility fields used by your bot commands
  storyChapter       Int               @default(1)
  storyStage         Int               @default(1)
  dungeonStage       Int               @default(1)
  towerFloor         Int               @default(1)

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  cards              UserCard[]
  equipment          UserEquipment[]
  listings           MarketListing[]
  deployments         Deployment[]
  teamSlots           TeamSlot[]
  storyProgress       StoryProgress?
  bossEntries         BossEventEntry[]
}

model Character {
  id            String     @id
  name          String
  anime         String
  rarity        Rarity
  element       String     @default("Neutral")
  imageUrl      String?
  auraName      String?
  auraColor     String?
  auraSecondary String?
  auraIntensity Float      @default(1.0)
  basePower     Int
  baseFarm      Int
  baseLuck      Int
  globalPrint   Int        @default(0)
  limited       Boolean    @default(false)
  banner        String?
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())

  cards         UserCard[]
}

model UserCard {
  id          String            @id
  userId      String
  characterId String
  serial      Int
  level       Int               @default(1)
  xp          Int               @default(0)
  power       Int
  locked      Boolean           @default(false)
  shiny       Boolean           @default(false)
  trait       String?
  gearTier    String            @default("COMMON")
  coreTier    Int               @default(0)
  skillTier   Int               @default(0)
  traitName   String?
  traitTier   Int               @default(0)
  bondTier    Int               @default(0)
  transformationTier Int         @default(0)
  variantTier Int               @default(0)
  element     String?
  role        String?
  obtainedAt  DateTime          @default(now())

  user        User              @relation(fields: [userId], references: [id])
  character   Character         @relation(fields: [characterId], references: [id])
  listings    MarketListing[]
  deployments Deployment[]
  teamSlots   TeamSlot[]
  equipment   UserEquipment[]

  @@index([userId])
  @@index([characterId, serial])
}

model EquipmentTemplate {
  id             String          @id
  name           String
  slot           EquipmentSlot
  rarity         Rarity
  basePower      Int
  imageUrl       String?
  active         Boolean         @default(true)

  // Compatibility fields used by item system
  bonusType      String?
  bonusValue     Int?
  characterHint  String?

  userEquipments UserEquipment[]
}

model UserEquipment {
  id         String            @id
  userId     String
  templateId String
  cardId     String?
  level      Int               @default(1)
  power      Int
  locked     Boolean           @default(false)
  createdAt  DateTime          @default(now())
  equippedAt DateTime?

  user       User              @relation(fields: [userId], references: [id])
  template   EquipmentTemplate @relation(fields: [templateId], references: [id])
  card       UserCard?         @relation(fields: [cardId], references: [id])

  @@index([userId])
  @@index([cardId])
  @@index([templateId])
}

model MarketListing {
  id        String        @id
  sellerId  String
  cardId    String
  price     BigInt
  status    ListingStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  soldAt    DateTime?

  seller    User          @relation(fields: [sellerId], references: [id])
  card      UserCard      @relation(fields: [cardId], references: [id])

  @@index([status, createdAt])
}

model Auction {
  id              String        @id
  cardId          String
  sellerId        String
  currentBid      BigInt        @default(0)
  currentBidderId String?
  endsAt          DateTime
  status          AuctionStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
}

model Deployment {
  id        String   @id
  userId    String
  cardId    String
  zone      String
  startedAt DateTime @default(now())
  endsAt    DateTime
  claimed   Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id])
  card      UserCard @relation(fields: [cardId], references: [id])
}

model TeamSlot {
  id        String   @id
  userId    String
  slot      Int
  cardId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  card      UserCard @relation(fields: [cardId], references: [id])

  @@unique([userId, slot])
}

model StoryProgress {
  id           String   @id
  userId       String
  chapter      Int      @default(1)
  stage        Int      @default(1)
  dungeonFloor Int      @default(1)
  towerFloor   Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId])
}

model BossEvent {
  id           String           @id
  bossName     String
  bossPower    Int
  bossHp       Int
  status       String           @default("JOINING")
  startedAt    DateTime         @default(now())
  joinEndsAt   DateTime
  battleEndsAt DateTime?
  rewardGold   Int              @default(0)
  rewardTokens Int              @default(0)
  createdAt    DateTime         @default(now())

  entries      BossEventEntry[]
}

model BossEventEntry {
  id       String    @id
  eventId  String
  userId   String
  damage   Int       @default(0)
  joinedAt DateTime  @default(now())

  event    BossEvent @relation(fields: [eventId], references: [id])
  user     User      @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model EconomyLog {
  id        String   @id
  userId    String
  type      String
  amount    BigInt
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Cooldown {
  userId    String
  key       String
  expiresAt DateTime

  @@id([userId, key])
}


// ============================
// VoidRoll Reborn New Models
// ============================

model UserResource {
  id        String   @id @default(cuid())
  userId    String
  name      String
  amount    BigInt   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model Formation {
  id         String   @id @default(cuid())
  userId     String
  type       String   @default("story")
  index      Int
  leaderSlot Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  slots      FormationSlot[]

  @@unique([userId, type, index])
  @@index([userId, type])
}

model FormationSlot {
  id          String   @id @default(cuid())
  formationId String
  slot        Int
  cardId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  formation   Formation @relation(fields: [formationId], references: [id], onDelete: Cascade)

  @@unique([formationId, slot])
  @@index([cardId])
}

model Pity {
  id                    String   @id @default(cuid())
  userId                String
  bannerId              String
  secret                Int      @default(0)
  voidborn              Int      @default(0)
  featuredGuaranteeNext Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, bannerId])
  @@index([userId])
}

model MarketPurchase {
  id         String   @id @default(cuid())
  userId     String
  marketType String
  refreshKey String
  itemId     String
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())

  @@unique([userId, marketType, refreshKey, itemId])
  @@index([userId, marketType])
}

model DungeonRun {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  currentRoom        Int      @default(1)
  requiredFormations Int      @default(1)
  rewardMultiplier   Float    @default(1)
  roomsJson          String
  completed          Boolean  @default(false)
  abandoned          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId, completed, abandoned])
}

model RaidBoss {
  id            String   @id @default(cuid())
  serverId      String
  templateId    String
  type          String
  name          String
  level         Int      @default(1)
  element       String
  role          String
  rarity        String
  maxHp         BigInt
  currentHp     BigInt
  basePower     BigInt
  phase         Int      @default(1)
  defeated      Boolean  @default(false)
  lastHitUserId String?
  startsAt      DateTime
  endsAt        DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  damageLogs    RaidDamageLog[]

  @@index([serverId, defeated])
  @@index([type])
}

model RaidDamageLog {
  id         String   @id @default(cuid())
  raidBossId String
  userId     String
  username   String?
  damage     BigInt   @default(0)
  createdAt  DateTime @default(now())

  raidBoss   RaidBoss @relation(fields: [raidBossId], references: [id], onDelete: Cascade)

  @@index([raidBossId])
  @@index([userId])
}

model PvpBattleLog {
  id           String   @id @default(cuid())
  attackerId   String
  defenderId   String
  result       String
  ratingBefore Int
  ratingAfter  Int
  ratingChange Int
  attackerWins Int
  defenderWins Int
  createdAt    DateTime @default(now())

  @@index([attackerId])
  @@index([defenderId])
}
