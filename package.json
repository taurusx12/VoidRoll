{
  "name": "anime-card-bot-global",
  "version": "1.0.0",
  "description": "Production-ready Discord anime card economy bot scaffold: gacha, inventory, AFK farming, equipment, market, auctions, raids, seasons.",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node src/index.js",
    "start": "node src/index.js",
    "commands:deploy": "node scripts/deploy-commands.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "seed": "node scripts/seed.js",
    "import:anime": "node scripts/import-anime.js",
    "health": "node scripts/healthcheck.js"
  },
  "dependencies": {
"@prisma/client": "5.22.0",
    "axios": "latest",
    "bullmq": "latest",
    "discord.js": "latest",
    "dotenv": "latest",
    "express": "latest",
    "ioredis": "latest",
    "nanoid": "latest",
    "prisma": "5.22.0",
    "zod": "latest",
    "sharp": "latest"
  }
}
